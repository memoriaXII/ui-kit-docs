NEXT_PUBLIC_APP_URL=http://localhost:4000
# Where the sibling Vite preview app lives. Used by docs/ to iframe live
# component demos. Defaults to http://127.0.0.1:4001 in dev; in production
# point this at your deployed preview project URL (no trailing slash).
NEXT_PUBLIC_PREVIEW_ORIGIN=http://127.0.0.1:4001
